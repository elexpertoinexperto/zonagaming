---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';

const title = 'Refrigeración normal';
const description = 'Ventiladores y disipadores para mantener tu PC fría con aire eficiente y silencioso.';
const productsData = productos['refrigeracion-normal'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/refrigeracion-normal/${p.slug}-${p.id}`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title={`${title} | Monckey Gamer`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} productos disponibles</span>
      <span>Opciones eficientes y accesibles</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/refrigeracion-normal/${product.slug}-${product.id}`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <section class="category-buying-guide">
    <h2>¿Vale la pena un cooler de aire?</h2>
    <p>Los coolers de torre son confiables, duraderos y ofrecen excelente relación precio-rendimiento:</p>
    <ul>
      <li>Las torres dobles (twin tower) compiten en rendimiento con AIOs de 240 mm.</li>
      <li>Sin riesgo de fugas ni bombas que puedan fallar con el tiempo.</li>
      <li>Verifica la altura máxima permitida por tu gabinete antes de comprar.</li>
      <li>La mayoría incluye pasta térmica de calidad en el paquete.</li>
      <li>Opción inteligente si priorizas durabilidad y bajo mantenimiento.</li>
    </ul>
  </section>

  <BestSellers
    id="mas-vendidos-refrigeracion-normal"
    title="Los más vendidos en Refrigeracion Normal"
    products={bestSellerProducts}
  />
</SiteLayout>
