---
import SiteLayout from '../../components/SiteLayout.astro';
import juegosRaw from '../../data/juegos-index.json';

const juegos = juegosRaw as typeof juegosRaw;

const catLabel: Record<string, string> = {
  'tarjetas-graficas': 'Tarjeta Gráfica',
  'procesadores': 'Procesador',
  'memoria-ram': 'Memoria RAM',
  'ssd': 'SSD',
  'refrigeracion-normal': 'Refrigeración',
  'refrigeracion-liquida': 'Refrigeración Líquida',
};

const catColor: Record<string, string> = {
  'tarjetas-graficas': '#7cffcb',
  'procesadores': '#7cc4ff',
  'memoria-ram': '#ffd97c',
  'ssd': '#ff9e7c',
  'refrigeracion-normal': '#b07cff',
  'refrigeracion-liquida': '#7cdbff',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Recomendador de Componentes por Juego | Monckey Gamer",
  "description": "Selecciona un juego y descubre qué componentes necesitas para correrlo al máximo rendimiento.",
  "url": "https://monckeygamer.com/recomendador/",
  "inLanguage": "es",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://monckeygamer.com/" },
      { "@type": "ListItem", "position": 2, "name": "Recomendador", "item": "https://monckeygamer.com/recomendador/" }
    ]
  }
};
---

<SiteLayout
  title="Recomendador de Componentes por Juego | Monckey Gamer"
  description="Selecciona un juego y descubre qué componentes PC necesitas para correrlo al máximo rendimiento. GPU, CPU y RAM recomendados para cada título."
  robots="index, follow"
  schema={schema}
>
  <main class="rec-page">

    <section class="rec-hero">
      <div class="rec-hero-inner">
        <span class="rec-eyebrow">🎮 Herramienta</span>
        <h1>Recomendador de componentes</h1>
        <p>Selecciona un juego y te mostramos exactamente qué GPU, CPU y RAM necesitas para correrlo al máximo.</p>
      </div>
    </section>

    <section class="rec-body">
      <div class="rec-search-wrap">
        <div class="rec-search-box">
          <svg class="rec-search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/>
            <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <input
            id="rec-search"
            type="search"
            placeholder="Busca un juego..."
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <p class="rec-count" id="rec-count">{juegos.length} juegos disponibles</p>
      </div>

      <div class="rec-grid" id="rec-grid">
        {juegos.map((juego, i) => (
          <button
            class="game-card"
            data-index={i}
            aria-pressed="false"
            type="button"
          >
            <div class="game-img-wrap">
              <img
                src={`https://cdn.akamai.steamstatic.com/steam/apps/${juego.steamId}/header.jpg`}
                alt={juego.titulo}
                loading="lazy"
                width="460"
                height="215"
                class="game-img"
              />
              <div class="game-img-overlay"></div>
            </div>
            <div class="game-info">
              <span class="game-genre">{juego.genero}</span>
              <span class="game-title">{juego.titulo}</span>
            </div>
            <div class="game-check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <polyline points="3,8 7,12 13,4" stroke="#7cffcb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
        ))}
      </div>

      <p class="rec-no-results" id="rec-no-results" hidden>No se encontraron juegos con ese nombre.</p>

      <div class="rec-panel" id="rec-panel" hidden>
        <div class="rec-panel-header" id="rec-panel-header">
          <div class="rec-panel-game">
            <img id="rec-panel-img" src="" alt="" width="120" height="56" loading="lazy" />
            <div>
              <p class="rec-panel-label">Componentes recomendados para</p>
              <h2 id="rec-panel-title"></h2>
              <span id="rec-panel-genre" class="rec-panel-genre"></span>
            </div>
          </div>
        </div>
        <div class="rec-cards" id="rec-cards"></div>
      </div>
    </section>

  </main>
</SiteLayout>

<script define:vars={{ juegos, catLabel, catColor }}>
  const searchEl = document.getElementById('rec-search');
  const grid = document.getElementById('rec-grid');
  const panel = document.getElementById('rec-panel');
  const panelTitle = document.getElementById('rec-panel-title');
  const panelImg = document.getElementById('rec-panel-img');
  const panelGenre = document.getElementById('rec-panel-genre');
  const panelCards = document.getElementById('rec-cards');
  const countEl = document.getElementById('rec-count');
  const noResults = document.getElementById('rec-no-results');
  const cards = Array.from(grid.querySelectorAll('.game-card'));

  let activeIndex = -1;

  function getProductPath(cat, slug, id) {
    return `/${cat}/${slug}-${id}/`;
  }

  function renderPanel(juego) {
    panelTitle.textContent = juego.titulo;
    panelGenre.textContent = juego.genero;
    panelImg.src = `https://cdn.akamai.steamstatic.com/steam/apps/${juego.steamId}/header.jpg`;
    panelImg.alt = juego.titulo;

    panelCards.innerHTML = juego.recomendaciones.map(rec => {
      const color = catColor[rec.categoria] || '#7cffcb';
      const label = catLabel[rec.categoria] || rec.categoria;
      const href = getProductPath(rec.categoria, rec.slug, rec.id);
      return `
        <div class="rec-card">
          <div class="rec-card-top">
            <span class="rec-cat-badge" style="color:${color};border-color:${color}22;background:${color}11">${label}</span>
          </div>
          <p class="rec-card-name">${rec.nombre}</p>
          <div class="rec-card-badges">
            <span class="rec-badge">${rec.resolucion}</span>
            <span class="rec-badge rec-badge-fps">${rec.fps}</span>
            <span class="rec-badge">${rec.setting}</span>
          </div>
          <p class="rec-card-razon">${rec.razon}</p>
          <a href="${href}" class="rec-card-link">
            Ver componente
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M8 4L11 7L8 10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      `;
    }).join('');
  }

  function selectGame(index) {
    if (activeIndex === index) {
      cards[activeIndex].setAttribute('aria-pressed', 'false');
      activeIndex = -1;
      panel.hidden = true;
      return;
    }
    if (activeIndex >= 0) {
      cards[activeIndex].setAttribute('aria-pressed', 'false');
    }
    activeIndex = index;
    cards[index].setAttribute('aria-pressed', 'true');
    renderPanel(juegos[index]);
    panel.hidden = false;
    setTimeout(() => {
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 50);
  }

  cards.forEach((card, i) => {
    card.addEventListener('click', () => selectGame(i));
  });

  searchEl.addEventListener('input', () => {
    const q = searchEl.value.trim().toLowerCase();
    let visible = 0;
    cards.forEach((card, i) => {
      const title = juegos[i].titulo.toLowerCase();
      const genre = juegos[i].genero.toLowerCase();
      const show = !q || title.includes(q) || genre.includes(q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = `${visible} juego${visible !== 1 ? 's' : ''} disponible${visible !== 1 ? 's' : ''}`;
    noResults.hidden = visible > 0;
  });
</script>

<style>
  .rec-page {
    min-height: 100vh;
  }

  /* Hero */
  .rec-hero {
    padding: 80px 2rem 48px;
    text-align: center;
    position: relative;
  }

  .rec-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    translate: -50% 0;
    width: 500px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(124,255,203,0.25), transparent);
  }

  .rec-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .rec-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7cffcb;
    background: rgba(124,255,203,0.07);
    border: 1px solid rgba(124,255,203,0.2);
    border-radius: 100px;
    padding: 5px 14px;
  }

  .rec-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #e6f7ff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .rec-hero p {
    color: #8aa0b8;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
    max-width: 560px;
  }

  /* Body */
  .rec-body {
    max-width: 1300px;
    margin: 0 auto;
    padding: 48px 2rem 80px;
  }

  /* Search */
  .rec-search-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: 40px;
  }

  .rec-search-box {
    position: relative;
    width: 100%;
    max-width: 520px;
  }

  .rec-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    translate: 0 -50%;
    color: #8aa0b8;
    pointer-events: none;
  }

  #rec-search {
    width: 100%;
    padding: 14px 16px 14px 48px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(124,255,203,0.2);
    border-radius: 12px;
    color: #e6f7ff;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    box-sizing: border-box;
  }

  #rec-search::placeholder { color: #4a6580; }

  #rec-search:focus {
    border-color: rgba(124,255,203,0.5);
    background: rgba(255,255,255,0.06);
  }

  .rec-count {
    font-size: 0.8rem;
    color: #4a6580;
    margin: 0;
  }

  /* Game grid */
  .rec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }

  .game-card {
    position: relative;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    text-align: left;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    display: flex;
    flex-direction: column;
  }

  .game-card:hover {
    border-color: rgba(124,255,203,0.3);
    box-shadow: 0 4px 24px rgba(124,255,203,0.06);
    transform: translateY(-2px);
  }

  .game-card[aria-pressed="true"] {
    border-color: #7cffcb;
    box-shadow: 0 0 0 1px #7cffcb, 0 8px 32px rgba(124,255,203,0.15);
  }

  .game-img-wrap {
    position: relative;
    aspect-ratio: 460/215;
    overflow: hidden;
  }

  .game-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .game-card:hover .game-img { transform: scale(1.04); }

  .game-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(7,27,53,0.7) 100%);
  }

  .game-info {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .game-genre {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7cffcb;
    opacity: 0.7;
  }

  .game-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: #c8d8e8;
    line-height: 1.3;
  }

  .game-check {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #7cffcb;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .game-card[aria-pressed="true"] .game-check { opacity: 1; }

  /* No results */
  .rec-no-results {
    text-align: center;
    color: #4a6580;
    font-size: 0.95rem;
    padding: 32px 0;
  }

  /* Panel */
  .rec-panel {
    border: 1px solid rgba(124,255,203,0.2);
    border-radius: 20px;
    background: rgba(7,27,53,0.6);
    backdrop-filter: blur(8px);
    overflow: hidden;
    animation: panel-in 0.25s ease;
  }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rec-panel-header {
    padding: 24px 28px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(124,255,203,0.03);
  }

  .rec-panel-game {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .rec-panel-game img {
    border-radius: 8px;
    object-fit: cover;
    flex: 0 0 auto;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  .rec-panel-label {
    font-size: 0.75rem;
    color: #4a6580;
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  #rec-panel-title {
    font-size: 1.4rem;
    font-weight: 800;
    color: #e6f7ff;
    margin: 0 0 6px;
    line-height: 1.2;
  }

  .rec-panel-genre {
    font-size: 0.75rem;
    font-weight: 600;
    color: #7cffcb;
    background: rgba(124,255,203,0.08);
    border: 1px solid rgba(124,255,203,0.2);
    border-radius: 100px;
    padding: 2px 10px;
  }

  /* Rec cards */
  .rec-cards {
    padding: 28px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .rec-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s;
  }

  .rec-card:hover {
    border-color: rgba(124,255,203,0.25);
  }

  .rec-card-top { display: flex; align-items: center; }

  .rec-cat-badge {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid;
    border-radius: 100px;
    padding: 3px 10px;
  }

  .rec-card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #e6f7ff;
    line-height: 1.3;
    margin: 0;
  }

  .rec-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .rec-badge {
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 2px 8px;
    color: #8aa0b8;
  }

  .rec-badge-fps {
    color: #7cffcb;
    border-color: rgba(124,255,203,0.2);
    background: rgba(124,255,203,0.05);
  }

  .rec-card-razon {
    font-size: 0.84rem;
    color: #6a8099;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .rec-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.84rem;
    font-weight: 600;
    color: #7cffcb;
    text-decoration: none;
    transition: gap 0.2s ease;
    margin-top: auto;
  }

  .rec-card-link:hover {
    gap: 10px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .rec-hero {
      padding: 60px 1.25rem 36px;
    }

    .rec-body {
      padding: 32px 1.25rem 60px;
    }

    .rec-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .rec-panel-game {
      flex-direction: column;
      align-items: flex-start;
    }

    .rec-panel-game img {
      width: 100%;
      height: auto;
    }

    .rec-cards {
      padding: 16px;
      grid-template-columns: 1fr;
    }

    .rec-panel-header {
      padding: 16px;
    }
  }

  @media (max-width: 400px) {
    .rec-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
