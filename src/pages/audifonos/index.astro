---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const title = 'Audífonos';
const metaDescription = "Audífonos gamer con sonido inmersivo y micrófono nítido. Escucha cada paso y juega mejor al mejor precio. ¡Sube tu nivel!";
const description = 'Audífonos gamer con sonido envolvente, micrófono claro y comodidad para largas sesiones.';
const productsData = productos['audifonos'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/audifonos/${p.slug}-${p.id}`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title={`${title} | Monckey Gamer`} description={metaDescription} robots="index, follow">
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
    <span>{productsData.length} productos disponibles</span>
      <span>Audio inmersivo y comunicación clara</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/audifonos/${product.slug}-${product.id}`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="audifonos" />

  <section class="category-buying-guide">
    <h2>¿Qué audífonos gamer necesitas?</h2>
    <p>Un buen par de audífonos mejora la inmersión y el posicionamiento de sonido en partidas competitivas:</p>
    <ul>
      <li>Diseño cerrado: aísla el entorno exterior; ideal para ambientes ruidosos.</li>
      <li>Diseño abierto: soundstage más amplio y natural; mejor para experiencias single-player.</li>
      <li>Sonido 7.1 virtual ayuda a detectar pasos y disparos por dirección en FPS.</li>
      <li>Drivers de 50 mm o más ofrecen mejor respuesta de bajos para efectos de impacto.</li>
      <li>Micrófono con cancelación de ruido es esencial para streaming o juego en equipo.</li>
    </ul>
  </section>

  <BestSellers
    id="mas-vendidos-audifonos"
    title="Los más vendidos en Audifonos"
    products={bestSellerProducts}
  />
</SiteLayout>
