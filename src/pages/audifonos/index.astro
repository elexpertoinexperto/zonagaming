---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const metaDescription = "Los mejores audífonos gamer con sonido 7.1 y micrófono nítido. Diademas gamer y cascos gamer al mejor precio con envío Amazon.";
const description = 'Los mejores audífonos gamer, diademas gamer y cascos gamer con sonido envolvente, micrófono con cancelación de ruido y comodidad para largas sesiones de juego.';
const productsData = productos['audifonos'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/audifonos/${p.slug}-${p.id}/`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title="Audífonos Gamer con Sonido 7.1 | Monckey Gamer" description={metaDescription} robots="index, follow" schema={{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://monckeygamer.com/" },
    { "@type": "ListItem", "position": 2, "name": "Audífonos Gamer", "item": "https://monckeygamer.com/audifonos/" }
  ]
}}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Diademas Gamer / Cascos Gamer</small>
    <h1>Audífonos Gamer</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} audífonos disponibles</span>
      <span>Stock validado y envío seguro vía Amazon</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/audifonos/${product.slug}-${product.id}/`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="audifonos" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tus audífonos gamer?</h2>
    <p>Unos buenos audífonos gamer mejoran la inmersión y el posicionamiento de sonido en partidas competitivas. Ya sea que busques diademas gamer para FPS o cascos gamer para inmersión total, estos son los factores clave:</p>
    <ul>
      <li><strong>Diseño cerrado:</strong> los audífonos gamer de diseño cerrado aíslan el entorno exterior; ideales para ambientes ruidosos y gaming competitivo.</li>
      <li><strong>Diseño abierto:</strong> las diademas gamer abiertas ofrecen un soundstage más amplio y natural; mejores para experiencias single-player.</li>
      <li><strong>Sonido 7.1 virtual:</strong> los cascos gamer con 7.1 ayudan a detectar pasos y disparos por dirección en FPS; ventaja real en competitivo.</li>
      <li><strong>Drivers de 50 mm:</strong> los audífonos gamer con drivers grandes ofrecen mejor respuesta de bajos para efectos de impacto y explosiones.</li>
      <li><strong>Micrófono:</strong> las diademas gamer con cancelación de ruido son esenciales para streaming o comunicación en equipo.</li>
    </ul>
    <p>Todos los audífonos gamer de nuestro catálogo están disponibles con envío directo desde Amazon, con garantía oficial y devoluciones sin complicaciones.</p>
  </section>

  <BestSellers
    id="mas-vendidos-audifonos"
    title="Audífonos Gamer más vendidos"
    products={bestSellerProducts}
  />
</SiteLayout>
