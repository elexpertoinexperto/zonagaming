---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const title = 'Procesadores';
const description = 'Selecciona CPUs potentes para gaming, streaming y multitarea con alto rendimiento.';
const productsData = productos['procesadores'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/procesadores/${p.slug}-${p.id}`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title={`${title} | Monckey Gamer`}>
  <section class="category-hero">
    <a class="category-back" href="/">Volver al Home</a>
    <small>Categoria</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} productos disponibles</span>
      <span>Rendimiento y estabilidad garantizados</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/procesadores/${product.slug}-${product.id}`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="procesadores" />

  <section class="category-buying-guide">
    <h2>¿Qué procesador te conviene?</h2>
    <p>El CPU determina cuántas tareas puedes correr a la vez y qué tan rápido responde tu PC. Puntos clave:</p>
    <ul>
      <li>Para gaming puro, la frecuencia (GHz) importa más que la cantidad de núcleos.</li>
      <li>6–8 núcleos son suficientes para jugar; 12 o más si también haces streaming o edición.</li>
      <li>AMD Ryzen e Intel Core son igual de competitivos; elige según tu placa madre.</li>
      <li>Verifica el socket: AM5 (AMD) o LGA1700/1851 (Intel) antes de comprar.</li>
      <li>El caché L3 grande mejora los FPS en juegos; vale la pena compararlo.</li>
    </ul>
  </section>

  <BestSellers
    id="mas-vendidos-procesadores"
    title="Los más vendidos en Procesadores"
    products={bestSellerProducts}
  />
</SiteLayout>
