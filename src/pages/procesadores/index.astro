---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const metaDescription = "Los mejores procesadores de PC para gaming: AMD Ryzen e Intel Core. CPU de computadora de alto rendimiento al mejor precio con envío Amazon.";
const description = 'Los mejores procesadores de PC para gaming, streaming y multitarea. Encuentra el CPU de computadora ideal para tu build con la mejor relación rendimiento/precio.';
const productsData = productos['procesadores'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/procesadores/${p.slug}-${p.id}/`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title="Procesadores de PC para Gaming | Monckey Gamer" description={metaDescription} robots="index, follow" schema={{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://monckeygamer.com/" },
    { "@type": "ListItem", "position": 2, "name": "Procesadores", "item": "https://monckeygamer.com/procesadores/" }
  ]
}}>
  <section class="category-hero">
    <a class="category-back" href="/">Volver al Home</a>
    <small>CPU de Computadora</small>
    <h1>Procesadores de PC</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} procesadores disponibles</span>
      <span>Stock validado y envío seguro vía Amazon</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/procesadores/${product.slug}-${product.id}/`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="procesadores" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tu procesador de PC para gaming?</h2>
    <p>El procesador de PC es el cerebro de tu build: determina cuántas tareas corres a la vez y qué tan rápido responde tu sistema. Ya sea que busques un CPU de computadora para gaming competitivo o para creación de contenido, estos son los factores clave:</p>
    <ul>
      <li><strong>Frecuencia (GHz):</strong> en procesadores de PC para gaming puro, el reloj alto importa más que el número de núcleos.</li>
      <li><strong>Núcleos e hilos:</strong> 6–8 núcleos son suficientes para jugar; 12 o más si tu CPU de computadora también maneja streaming o edición.</li>
      <li><strong>AMD Ryzen vs Intel Core:</strong> ambas marcas ofrecen procesadores de PC competitivos; elige según tu placa madre y presupuesto.</li>
      <li><strong>Socket:</strong> verifica AM5 (AMD) o LGA1700/1851 (Intel) antes de comprar tu procesador de PC.</li>
      <li><strong>Caché L3:</strong> un caché L3 grande mejora los FPS en juegos; compáralo al evaluar CPUs de computadora.</li>
    </ul>
    <p>Todos los procesadores de PC de nuestro catálogo están disponibles con envío directo desde Amazon, con garantía oficial y devoluciones sin complicaciones.</p>
  </section>

  <BestSellers
    id="mas-vendidos-procesadores"
    title="Procesadores de PC más vendidos"
    products={bestSellerProducts}
  />
</SiteLayout>
