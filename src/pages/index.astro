---
import '../styles.css';
import Header from '../components/Header.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import BestSellers from '../components/BestSellers.astro';
import productos from '../data/productos.json';

const tg  = (productos['tarjetas-graficas'] as any[]);
const cpu = (productos['procesadores'] as any[]);
const ram = (productos['memoria-ram'] as any[]);

const categories = [
  { label: 'Tarjetas gráficas', slug: '/tarjetas-graficas', icon: 'gpu', description: 'Potencia visual para gaming y edición.' },
  { label: 'Procesadores', slug: '/procesadores', icon: 'cpu', description: 'CPU para multitarea y rendimiento extremo.' },
  { label: 'Memoria RAM', slug: '/memoria-ram', icon: 'ram', description: 'Velocidad y capacidad para tus builds.' },
  { label: 'SSD', slug: '/ssd', icon: 'ssd', description: 'Almacenamiento rápido para juegos y programas.' },
  { label: 'Fuentes de poder', slug: '/fuentes-de-poder', icon: 'psu', description: 'Energía estable y eficiente para tu PC.' },
  { label: 'Refrigeración líquida', slug: '/refrigeracion-liquida', icon: 'aio', description: 'Enfriamiento silencioso y de alto rendimiento.' },
  { label: 'Refrigeración normal', slug: '/refrigeracion-normal', icon: 'fan', description: 'Ventiladores confiables para tu torre.' },
  { label: 'Gabinetes gamer', slug: '/gabinetes-gamer', icon: 'box', description: 'Estética, flujo de aire y espacio para tu setup.' },
  { label: 'Teclados', slug: '/teclados', icon: 'keyboard', description: 'Periféricos mecánicos y RGB para cada tipo de jugador.' },
  { label: 'Mouse', slug: '/mouse', icon: 'mouse', description: 'Precisión y ergonomía para juegos competitivos.' },
  { label: 'Audífonos', slug: '/audifonos', icon: 'audio', description: 'Sonido inmersivo para tus partidas y streaming.' },
];

const bestSellerProducts = [
  {
    id: 1,
    name: 'ZOTAC GeForce GTX 960',
    description: 'Tarjeta gráfica de gama media con 2GB de VRAM GDDR5, ideal para gaming y trabajo en video.',
    price: '$200.00 USD',
    imageUrl: tg.find(p => p.id === 1)?.imagenUrl || '/placeholder-product.svg',
    detailHref: '/tarjetas-graficas/zotac-geforce-gtx-960-1',
    amazonHref: 'https://amzn.to/4vfFX2q',
  },
  {
    id: 2,
    name: 'Intel Core i9-13900K',
    description: 'Procesador tope de gama para gaming, streaming y multitarea exigente.',
    price: '$589.99 USD',
    imageUrl: cpu.find(p => p.id === 1)?.imagenUrl || '/placeholder-product.svg',
    detailHref: '/procesadores/intel-core-i9-13900k-1',
    amazonHref: 'https://amazon.com/dp/',
  },
  {
    id: 3,
    name: 'Corsair Dominator Platinum RGB 32GB 6000MHz',
    description: 'Memoria DDR5 de alto rendimiento con RGB sincronizable para builds premium.',
    price: '$189.99 USD',
    imageUrl: ram.find(p => p.id === 1)?.imagenUrl || '/placeholder-product.svg',
    detailHref: '/memoria-ram/corsair-dominator-platinum-rgb-32gb-6000mhz-1',
    amazonHref: 'https://amazon.com/dp/',
  },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Tienda de componentes PC para gamers. Encuentra tarjetas gráficas, procesadores, memoria RAM, SSD, fuentes de poder y más. Calidad premium y asesoría experta para tu setup gamer." />
    <title> Componentes PC Gamer | Mockey Gamer</title>
  </head>
  <body>
    <div class="page">
      <Header />

      <section class="hero">
        <div class="hero-copy">
          <h1>Componentes PC - Tienda Gamer</h1>
          <p class="hero-copy-description">Equipos y componentes que elevan tu rendimiento al siguiente nivel.</p>
          <p>Descubre un catálogo curado de piezas para armado de PC, desde tarjetas gráficas y fuentes hasta teclados mecánicos y enfriamiento líquido. Diseño minimalista, velocidad máxima y estilo gamer real.</p>
          <div class="hero-actions">
            <button class="btn">Los Más Vendidos </button>            
          </div>

          <div class="hero-stats">
            <div class="stat-card">
              <strong>+70</strong>
              Componentes pensados para gaming.
            </div>
            <div class="stat-card">
              <strong>24h</strong>
              Disponible para ti.
            </div>
            <div class="stat-card">
              <strong>Garantía</strong>
              Garantía directa con Amazon.
            </div>
          </div>
        </div>

        <div class="hero-visual">
          <div class="visual-panel">
            <h2>Lleva tu setup al podio hoy</h2>
            <p>Haz que cada partida sea más inmersiva con hardware confiable, iluminación sutil y un diseño que queda perfecto en tu escritorio.</p>
          </div>
        </div>
      </section>

      <section id="categorias" class="categories">
        <div class="section-title">
          <small>Categorías</small>
          <h2>Encuentra el componente ideal</h2>
        </div>
        <div class="category-grid">
          {categories.map((category) => (
            <a class="category-card" href={category.slug}>
              <span class="category-icon">
                <CategoryIcon name={category.icon} />
              </span>
              <div>
                <h3>{category.label}</h3>
                <p>{category.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <BestSellers
        id="coleccion"
        title="Los más vendidos"        
        products={bestSellerProducts}
      />

      <section id="ventajas" class="features">
        <div class="section-title">
          <small>Por qué visitar en Mockey Gamer</small>
          <h2>Ventajas del setup gamer</h2>
        </div>
        <div class="feature-list">
          <div class="feature-item">
            <div>1</div>
            <div class="feature-content">
              <strong>Componetes de Alta Calidad</strong>
              <p>Aquí encontrarás los mejores componentes para tu setup gamer. y los podrás comprar a traves de Amazon.</p>
            </div>
          </div>
          <div class="feature-item">
            <div>2</div>
            <div class="feature-content">
              <strong>Calidad premium</strong>
              <p>Seleccionamos componentes de marcas reconocidas con rendimiento estable y duradero.</p>
            </div>
          </div>
          <div class="feature-item">
            <div>3</div>
            <div class="feature-content">
              <strong>Blogs interesantes</strong>
              <p>Publicaré un blog interesante con consejos y actualizaciones sobre el mundo del gaming.</p>
            </div>
          </div>
        </div>
      </section>

      <footer id="contacto">
        <div>Zona Gaming · Venta de componentes PC · Minimalismo gamer</div>
        <div>¿Listo para mejorar tu setup? Contacto: hola@zonagaming.com</div>
      </footer>
    </div>
  </body>
</html>
