---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const title = 'Mouse';
const description = 'Ratones gaming ergonómicos con alta precisión y verdad táctil para cada tipo de jugador.';
const productsData = productos['mouse'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/mouse/${p.slug}-${p.id}`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title={`${title} | Monckey Gamer`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
    <span>{productsData.length} productos disponibles</span>
      <span>Precisión y control para tu gameplay</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/mouse/${product.slug}-${product.id}`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="mouse" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir el mouse gamer correcto?</h2>
    <p>El mouse adecuado marca la diferencia en precisión y comodidad durante horas de juego:</p>
    <ul>
      <li>Sensor óptico es la elección para gaming competitivo; consistente en cualquier superficie.</li>
      <li>El DPI alto no mejora la puntería; lo importante es la consistencia del sensor.</li>
      <li>Ergonomía: palmgrip (palma apoyada), claw (dedos doblados) o fingertip según tu estilo.</li>
      <li>Los inalámbricos modernos tienen latencia imperceptible; no sacrificas rendimiento.</li>
      <li>Peso: ratones de 60–90 g favorecen la velocidad en FPS; más pesados para mayor control.</li>
    </ul>
  </section>

  <BestSellers
    id="mas-vendidos-mouse"
    title="Los más vendidos en Mouse"
    products={bestSellerProducts}
  />
</SiteLayout>
