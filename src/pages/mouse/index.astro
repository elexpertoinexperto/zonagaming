---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const metaDescription = "Los mejores mouse gamer ópticos y ergonómicos para gaming competitivo. Ratón gamer con sensor de precisión al mejor precio con envío Amazon.";
const description = 'Los mejores mouse gamer y ratón gamer para gaming competitivo. Sensores ópticos de alta precisión, diseño ergonómico y máxima velocidad para cada tipo de jugador.';
const productsData = productos['mouse'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/mouse/${p.slug}-${p.id}/`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title="Mouse Gamer de Alta Precisión | Monckey Gamer" description={metaDescription} robots="index, follow" schema={{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://monckeygamer.com/" },
    { "@type": "ListItem", "position": 2, "name": "Mouse Gamer", "item": "https://monckeygamer.com/mouse/" }
  ]
}}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Ratón Gamer</small>
    <h1>Mouse Gamer</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} mouse disponibles</span>
      <span>Stock validado y envío seguro vía Amazon</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/mouse/${product.slug}-${product.id}/`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="mouse" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tu mouse gamer?</h2>
    <p>El mouse gamer correcto marca la diferencia en precisión, velocidad y comodidad durante horas de juego. Ya sea que busques un ratón gamer ligero para FPS o uno ergonómico para sesiones largas, estos son los factores clave:</p>
    <ul>
      <li><strong>Sensor óptico:</strong> el estándar en todo mouse gamer competitivo; respuesta consistente en cualquier superficie sin aceleración.</li>
      <li><strong>DPI:</strong> en un ratón gamer, el DPI alto no mejora la puntería por sí solo; lo importante es la consistencia y precisión del sensor.</li>
      <li><strong>Agarre:</strong> elige tu mouse gamer según tu estilo — palmgrip (palma apoyada), claw (dedos doblados) o fingertip.</li>
      <li><strong>Inalámbrico:</strong> los ratón gamer wireless modernos tienen latencia imperceptible; no sacrificas rendimiento competitivo.</li>
      <li><strong>Peso:</strong> un mouse gamer de 60–90 g favorece la velocidad en FPS; modelos más pesados ofrecen mayor control en RTS y MMO.</li>
    </ul>
    <p>Todos los mouse gamer de nuestro catálogo están disponibles con envío directo desde Amazon, con garantía oficial y devoluciones sin complicaciones.</p>
  </section>

  <BestSellers
    id="mas-vendidos-mouse"
    title="Mouse Gamer más vendidos"
    products={bestSellerProducts}
  />
</SiteLayout>
