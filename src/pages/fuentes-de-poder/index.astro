---
import SiteLayout from '../../components/SiteLayout.astro';
const title = 'Fuentes de poder';
const description = 'Fuentes modulares y certificadas para entregar energía limpia y segura a tu PC gamer.';
const products = [
  { name: 'Corsair RM850x', price: '$159 USD', description: '85+ Gold, silenciosa y con cableado modular completo.' },
  { name: 'Seasonic Focus GX-750', price: '$139 USD', description: 'Alta eficiencia y rendimiento estable bajo carga pesada.' },
  { name: 'NZXT C750', price: '$129 USD', description: 'Diseño compacto y controles para tu build moderna.' },
];
---

<SiteLayout title={`${title} | Zona Gaming`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{products.length} productos disponibles</span>
      <span>Protección completa para tu equipo</span>
    </div>
  </section>

  <section class="product-grid">
    {products.map((product) => (
      <article class="product-card">
        <h3>{product.name}</h3>
        <p>{product.description}</p>
        <span>{product.price}</span>
      </article>
    ))}
  </section>
</SiteLayout>
