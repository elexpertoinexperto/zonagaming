---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const metaDescription = "Las mejores fuentes de poder para PC: certificadas 80+, modulares y eficientes. Fuente de poder para PC y fuente de alimentación PC al mejor precio con envío Amazon.";
const description = 'Las mejores fuentes de poder para PC, modulares y certificadas 80+. Encuentra tu fuente de alimentación PC ideal para proteger tu build y entregar energía limpia y estable.';
const productsData = productos['fuentes-de-poder'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/fuentes-de-poder/${p.slug}-${p.id}/`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title="Fuentes de Poder para PC Gaming | Monckey Gamer" description={metaDescription} robots="index, follow" schema={{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://monckeygamer.com/" },
    { "@type": "ListItem", "position": 2, "name": "Fuentes de Poder", "item": "https://monckeygamer.com/fuentes-de-poder/" }
  ]
}}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Fuente de Alimentación PC</small>
    <h1>Fuentes de Poder</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} fuentes de poder disponibles</span>
      <span>Stock validado y envío seguro vía Amazon</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/fuentes-de-poder/${product.slug}-${product.id}/`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="fuentes-de-poder" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tu fuente de poder para PC?</h2>
    <p>La fuente de poder es el componente que protege toda tu inversión. Una fuente de alimentación PC de mala calidad puede dañar tu GPU, CPU o RAM. Estos son los factores clave:</p>
    <ul>
      <li><strong>Vatios:</strong> calcula el consumo total de tu build y añade un 20–30% de margen; una buena fuente de poder para PC nunca trabaja al límite.</li>
      <li><strong>Certificación 80+:</strong> Gold o superior en tu fuente de alimentación PC garantiza mayor eficiencia energética y menos calor generado.</li>
      <li><strong>Modular o semi-modular:</strong> una fuente de poder modular simplifica el cableado y mejora el flujo de aire en el gabinete.</li>
      <li><strong>Protecciones:</strong> la fuente de alimentación PC debe incluir protección contra sobrevoltaje, sobrecorriente y cortocircuito.</li>
      <li><strong>Marcas:</strong> Corsair, Seasonic y be quiet! son referentes en fuentes de poder para PC con excelente reputación y garantía.</li>
    </ul>
    <p>Todas las fuentes de poder de nuestro catálogo están disponibles con envío directo desde Amazon, con garantía oficial y devoluciones sin complicaciones.</p>
  </section>

  <BestSellers
    id="mas-vendidos-fuentes-de-poder"
    title="Fuentes de Poder más vendidas"
    products={bestSellerProducts}
  />
</SiteLayout>
