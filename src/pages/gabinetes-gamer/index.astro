---
import SiteLayout from '../../components/SiteLayout.astro';
const title = 'Gabinetes gamer';
const description = 'Gabinetes con flujo de aire, diseño gamer y espacio para builds potentes y RGB.';
const products = [
  { name: 'Lian Li Lancool II', price: '$149 USD', description: 'Gabinete espacioso con excelente gestión de cables y refrigeración.' },
  { name: 'NZXT H510 Flow', price: '$109 USD', description: 'Diseño moderno con panel frontal ventilado y montaje sencillo.' },
  { name: 'Corsair 5000D Airflow', price: '$159 USD', description: 'Perfecto para builds de alto rendimiento y refrigeración directa.' },
];
---

<SiteLayout title={`${title} | Zona Gaming`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{products.length} productos disponibles</span>
      <span>Estilo y rendimiento en una sola torre</span>
    </div>
  </section>

  <section class="product-grid">
    {products.map((product) => (
      <article class="product-card">
        <h3>{product.name}</h3>
        <p>{product.description}</p>
        <span>{product.price}</span>
      </article>
    ))}
  </section>
</SiteLayout>
