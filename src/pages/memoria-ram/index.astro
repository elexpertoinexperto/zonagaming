---
import SiteLayout from '../../components/SiteLayout.astro';
const title = 'Memoria RAM';
const description = 'Módulos DDR5 y DDR4 optimizados para velocidad, capacidad y estabilidad en cada build.';
const products = [
  { name: 'Corsair Vengeance DDR5 32GB', price: '$159 USD', description: 'Ideal para multitarea y gaming con overclock seguro.' },
  { name: 'G.Skill Trident Z5 RGB 32GB', price: '$189 USD', description: 'Rendimiento premium con diseño gamer y RGB personalizable.' },
  { name: 'Kingston Fury Beast 16GB', price: '$84 USD', description: 'Compatibilidad amplia y buena velocidad para PC de juegos.' },
];
---

<SiteLayout title={`${title} | Zona Gaming`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{products.length} productos disponibles</span>
      <span>Latencia baja y overclock estable</span>
    </div>
  </section>

  <section class="product-grid">
    {products.map((product) => (
      <article class="product-card">
        <h3>{product.name}</h3>
        <p>{product.description}</p>
        <span>{product.price}</span>
      </article>
    ))}
  </section>
</SiteLayout>
