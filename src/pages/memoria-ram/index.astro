---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const title = 'Memoria RAM';
const description = 'Modulos DDR5 y DDR4 optimizados para velocidad, capacidad y estabilidad en cada build.';
const productsData = productos['memoria-ram'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/memoria-ram/${p.slug}-${p.id}`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title={`${title} | Monckey Gamer`}>
  <section class="category-hero">
    <a class="category-back" href="/">Volver al Home</a>
    <small>Categoria</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} productos disponibles</span>
      <span>Compatibilidad probada con principales placas base</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/memoria-ram/${product.slug}-${product.id}`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="memoria-ram" />

  <section class="category-buying-guide">
    <h2>¿Cuánta RAM necesitas para gaming?</h2>
    <p>La RAM afecta la fluidez general del sistema y los tiempos de carga. Lo que debes saber:</p>
    <ul>
      <li>16 GB es el mínimo recomendado; 32 GB si combinas juegos con streaming o edición.</li>
      <li>DDR5 es el estándar actual; DDR4 sigue siendo válida en plataformas anteriores.</li>
      <li>Instala siempre en pares (dual channel) para aprovechar el doble de ancho de banda.</li>
      <li>La velocidad (MHz) y latencia (CL) impactan más en plataformas AMD Ryzen.</li>
      <li>Activa XMP/EXPO en la BIOS para correr la RAM a su frecuencia real.</li>
    </ul>
  </section>

  <BestSellers
    id="mas-vendidos-memoria-ram"
    title="Los más vendidos en Memoria Ram"
    products={bestSellerProducts}
  />
</SiteLayout>
