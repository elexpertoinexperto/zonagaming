---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
const title = 'Teclados';
const description = 'Teclados mecánicos y gaming con iluminación y teclas rápidas para cada estilo de jugada.';
const products = [
  { name: 'Razer Huntsman V2', price: '$199 USD', description: 'Switches ópticos para actuación instantánea y RGB personalizable.' },
  { name: 'Logitech G Pro X', price: '$149 USD', description: 'Teclado compacto con switches intercambiables y diseño premium.' },
  { name: 'Corsair K70 RGB', price: '$169 USD', description: 'Resistente, con reposamuñecas y múltiples opciones de iluminación.' },
];
---

<SiteLayout title={`${title} | Zona Gaming`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{products.length} productos disponibles</span>
      <span>Precisión y estilo para tu setup</span>
    </div>
  </section>

  <section class="product-grid">
    {products.map((product) => (
      <ProductCard product={product} />
    ))}
  </section>
</SiteLayout>
