---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const metaDescription = "Los mejores teclados gamer mecánicos y RGB. Teclado gaming con switches premium y respuesta precisa al mejor precio con envío Amazon.";
const description = 'Los mejores teclados gamer mecánicos con iluminación RGB y switches rápidos. Encuentra tu teclado gaming ideal para gaming competitivo y cada estilo de jugada.';
const productsData = productos['teclados'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/teclados/${p.slug}-${p.id}/`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title="Teclados Gamer Mecánicos | Monckey Gamer" description={metaDescription} robots="index, follow" schema={{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://monckeygamer.com/" },
    { "@type": "ListItem", "position": 2, "name": "Teclados Gamer", "item": "https://monckeygamer.com/teclados/" }
  ]
}}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Teclado Gaming</small>
    <h1>Teclados Gamer</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} teclados disponibles</span>
      <span>Stock validado y envío seguro vía Amazon</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/teclados/${product.slug}-${product.id}/`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="teclados" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tu teclado gamer?</h2>
    <p>El teclado gamer es tu principal herramienta de control en cada partida. Ya sea que busques un teclado gaming mecánico de alto rendimiento o una opción económica, estos factores marcan la diferencia:</p>
    <ul>
      <li><strong>Switches lineales (Red):</strong> el teclado gamer más rápido para gaming de acción; pulsación suave sin punto de activación.</li>
      <li><strong>Switches táctiles (Brown):</strong> un teclado gaming con feedback perceptible sin ruido excesivo, ideal para gaming y escritura mixta.</li>
      <li><strong>Formato TKL:</strong> el teclado gamer sin numpad libera espacio en el escritorio y da mayor rango de movimiento al mouse.</li>
      <li><strong>Hotswappable:</strong> permite cambiar los switches de tu teclado gaming sin necesidad de soldar; ideal para personalizar.</li>
      <li><strong>Polling rate:</strong> 1,000 Hz es el estándar en teclados gamer; suficiente para cualquier nivel competitivo.</li>
    </ul>
    <p>Todos los teclados gamer de nuestro catálogo están disponibles con envío directo desde Amazon, con garantía oficial y devoluciones sin complicaciones.</p>
  </section>

  <BestSellers
    id="mas-vendidos-teclados"
    title="Teclados Gamer más vendidos"
    products={bestSellerProducts}
  />
</SiteLayout>
