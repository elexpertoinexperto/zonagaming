---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductoDetalle from '../../components/ProductoDetalle.astro';
import productos from '../../data/productos.json';

export function getStaticPaths() {
  const productosCategoria = productos['tarjetas-graficas' as keyof typeof productos];
  return productosCategoria.map((p: any) => ({
    params: { id: String(p.id) }
  }));
}

const { id } = Astro.params;
const categoria = 'tarjetas-graficas';
const productosCategoria = productos[categoria as keyof typeof productos];
const producto = productosCategoria.find((p: any) => p.id === parseInt(id!));

if (!producto) {
  return Astro.redirect('/tarjetas-graficas');
}
---

<SiteLayout title={`${producto.nombre} | Zona Gaming`}>
  <div class="producto-header">
    <a class="back-link" href="/tarjetas-graficas">← Volver a Tarjetas Gráficas</a>
  </div>
  
  <ProductoDetalle 
    nombre={producto.nombre}
    descripcion={producto.descripcion}
    especificaciones={producto.especificaciones}
    precio={producto.precio}
    enlaceAmazon={producto.enlaceAmazon}
    imagenPath={`/tarjetas-graficas/${id}/imagenes/producto.svg`}
  />
</SiteLayout>

<style>
  .producto-header {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .back-link {
    color: #3b82f6;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: #1d4ed8;
  }
</style>
