---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const title = 'Tarjetas gráficas';
const description = 'Encuentra tarjetas graficas para juegos, streaming y renderizado con la mejor relacion rendimiento/precio.';
const productsData = productos['tarjetas-graficas'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/tarjetas-graficas/${p.slug}-${p.id}`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title={`${title} | Monckey Gamer`}>
  <section class="category-hero">
    <a class="category-back" href="/">Volver al Home</a>
    <small>Categoria</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} productos disponibles</span>
      <span>Stock validado y envio seguro</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl, // reemplaza imagenUrl en productos.json con la URL real
        detailHref: `/tarjetas-graficas/${product.slug}-${product.id}`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="tarjetas-graficas" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tu tarjeta gráfica?</h2>
    <p>La GPU define la calidad visual y los FPS de tu setup. Estos son los factores que realmente importan antes de comprar:</p>
    <ul>
      <li>VRAM: 8 GB para 1080p, 12 GB o más para 1440p y 4K.</li>
      <li>Resolución objetivo: no gastes de más si juegas en Full HD.</li>
      <li>DLSS (NVIDIA) y FSR (AMD) elevan el rendimiento sin perder calidad visual.</li>
      <li>Ray tracing es exigente; prioriza framerate alto en modo competitivo.</li>
      <li>Confirma que tu fuente tenga los conectores y vatios necesarios para el TDP de la GPU.</li>
    </ul>
  </section>

  <BestSellers
    id="mas-vendidos-tarjetas-graficas"
    title="Los más vendidos en Tarjetas Graficas"
    products={bestSellerProducts}
  />
</SiteLayout>
