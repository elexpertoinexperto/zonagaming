---
import SiteLayout from '../../components/SiteLayout.astro';
const title = 'Tarjetas gráficas';
const description = 'Encuentra tarjetas gráficas para juegos, streaming y renderizado con la mejor relación rendimiento/precio.';
const products = [
  { name: 'RTX 4090 Fury', price: '$1,899 USD', description: 'Rendimiento top para 4K y ray tracing sin límites.' },
  { name: 'RX 7900 XT', price: '$1,099 USD', description: 'Excelente balance entre potencia y precio para esports.' },
  { name: 'RTX 4080 Ultra', price: '$1,099 USD', description: 'Ideal para edición, gaming AAA y productividad avanzada.' },
  { name: 'RX 7800 XT', price: '$749 USD', description: 'Gran opción para 1440p con altas tasas de refresco.' },
];
---

<SiteLayout title={`${title} | Zona Gaming`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{products.length} productos disponibles</span>
      <span>Stock validado y envío seguro</span>
    </div>
  </section>

  <section class="product-grid">
    {products.map((product) => (
      <article class="product-card">
        <h3>{product.name}</h3>
        <p>{product.description}</p>
        <span>{product.price}</span>
      </article>
    ))}
  </section>
</SiteLayout>
