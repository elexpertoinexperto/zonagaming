---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestSellers from '../../components/BestSellers.astro';
import type { Producto } from '../../types/productos';
import productos from '../../data/productos.json';
import Comparador from '../../components/Comparador.astro';

const metaDescription = "La mejor refrigeración líquida para PC gaming: AIOs 240 mm y 360 mm. Sistema de refrigeración de PC con enfriamiento líquido silencioso al mejor precio con envío Amazon.";
const description = 'La mejor refrigeración líquida para PC y sistemas de refrigeración de PC AIO. Enfriamiento líquido silencioso y eficiente para gaming con overclocking y RGB.';
const productsData = productos['refrigeracion-liquida'] as unknown as Producto[];
const bestSellerProducts = productsData.slice(0, 3).map((p) => ({
  id: p.id,
  name: p.nombre,
  description: p.descripcion,
  price: `$${p.precio.toFixed(2)} USD`,
  imageUrl: p.imagenUrl,
  detailHref: `/refrigeracion-liquida/${p.slug}-${p.id}/`,
  amazonHref: p.enlaceAmazon,
}));
---

<SiteLayout title="Refrigeración Líquida para PC Gaming | Monckey Gamer" description={metaDescription} robots="index, follow">
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Sistema de Refrigeración de PC AIO</small>
    <h1>Refrigeración Líquida</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} sistemas disponibles</span>
      <span>Stock validado y envío seguro vía Amazon</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <ProductCard product={{
        id: product.id,
        name: product.nombre,
        price: `$${product.precio.toFixed(2)} USD`,
        description: product.descripcion,
        imageUrl: product.imagenUrl,
        detailHref: `/refrigeracion-liquida/${product.slug}-${product.id}/`,
        amazonHref: product.enlaceAmazon,
      }} />
    ))}
  </section>

  <Comparador categoriaFija="refrigeracion-liquida" />

  <section class="category-buying-guide">
    <h2>¿Cómo elegir tu refrigeración líquida para PC?</h2>
    <p>La refrigeración líquida para PC es la opción premium para mantener temperaturas bajas con el mínimo ruido y un look limpio. Ya sea que busques un sistema de refrigeración de PC básico o enfriamiento líquido para overclocking, estos son los factores clave:</p>
    <ul>
      <li><strong>Tamaño del radiador:</strong> 240 mm es suficiente para CPUs de gama media; elige 360 mm si tu sistema de refrigeración de PC va a soportar overclocking intensivo.</li>
      <li><strong>Silencio:</strong> la refrigeración líquida para PC es más silenciosa que la mayoría de coolers de aire de alto rendimiento.</li>
      <li><strong>Instalación:</strong> coloca el radiador de tu sistema de enfriamiento líquido en zonas de extracción para expulsar el calor del gabinete eficientemente.</li>
      <li><strong>Compatibilidad de socket:</strong> verifica que tu refrigeración líquida para PC sea compatible con tu socket AM5, LGA1700 u otro antes de comprar.</li>
      <li><strong>Espacio:</strong> el enfriamiento líquido es ideal para gabinetes compactos donde un cooler de torre de aire no tiene espacio suficiente.</li>
    </ul>
    <p>Todos los sistemas de refrigeración de PC de nuestro catálogo están disponibles con envío directo desde Amazon, con garantía oficial y devoluciones sin complicaciones.</p>
  </section>

  <BestSellers
    id="mas-vendidos-refrigeracion-liquida"
    title="Refrigeración Líquida más vendida"
    products={bestSellerProducts}
  />
</SiteLayout>
