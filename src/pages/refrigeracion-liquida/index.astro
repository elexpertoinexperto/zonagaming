---
import SiteLayout from '../../components/SiteLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import productos from '../../data/productos.json';

const title = 'Refrigeración líquida';
const description = 'Sistemas de enfriamiento líquido para mantener temperaturas bajas y ruido mínimo en tu equipo.';
const productsData = productos['refrigeracion-liquida'];
---

<SiteLayout title={`${title} | Zona Gaming`}>
  <section class="category-hero">
    <a class="category-back" href="/">← Volver al Home</a>
    <small>Categoría</small>
    <h1>{title}</h1>
    <p class="category-description">{description}</p>
    <div class="category-meta">
      <span>{productsData.length} productos disponibles</span>
      <span>Enfriamiento extremo con estilo</span>
    </div>
  </section>

  <section class="product-grid">
    {productsData.map((product) => (
      <a href={`/refrigeracion-liquida/${product.slug}-${product.id}`} class="product-link">
        <ProductCard product={{
          id: product.id,
          name: product.nombre,
          price: `$${product.precio.toFixed(2)} USD`,
          description: product.descripcion,
        }} />
      </a>
    ))}
  </section>
</SiteLayout>
