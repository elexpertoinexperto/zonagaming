---
import SiteLayout from '../../../components/SiteLayout.astro';
import { ARTICLES_EN, BLOG_EN } from '../../../i18n/en';

const articulos = ARTICLES_EN;
---

<SiteLayout
  title={BLOG_EN.pageTitle}
  description={BLOG_EN.metaDescription}
  robots="index, follow"
>
  <section class="category-hero">
    <small>{BLOG_EN.eyebrow}</small>
    <h1>{BLOG_EN.heroTitle}</h1>
    <p class="category-description">{BLOG_EN.heroDescription}</p>
  </section>

  <section class="blog-grid">
    {articulos.map((art) => (
      <a class="blog-card" href={art.href}>
        <span class="blog-card-tag">{art.tag}</span>
        <h2>{art.titulo}</h2>
        <p>{art.resumen}</p>
        <div class="blog-card-meta">
          <span>{art.fecha}</span>
          <span class="blog-card-dot"></span>
          <span>{art.tiempoLectura} {BLOG_EN.readTime}</span>
        </div>
        <span class="blog-card-link">{BLOG_EN.readArticle}</span>
      </a>
    ))}
  </section>
</SiteLayout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    border-color: rgba(124, 255, 203, 0.4);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
  }

  .blog-card-tag {
    align-self: flex-start;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7cffcb;
    background: rgba(124, 255, 203, 0.08);
    border: 1px solid rgba(124, 255, 203, 0.2);
    padding: 5px 12px;
    border-radius: 999px;
  }

  .blog-card h2 {
    margin: 16px 0 12px;
    font-size: 1.35rem;
    line-height: 1.3;
    color: #e6f7ff;
  }

  .blog-card p {
    margin: 0 0 18px;
    color: #c8d8e8;
    line-height: 1.7;
    font-size: 0.95rem;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #8aa0b8;
    font-size: 0.85rem;
    margin-bottom: 14px;
  }

  .blog-card-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #8aa0b8;
  }

  .blog-card-link {
    color: #7cffcb;
    font-weight: 700;
    font-size: 0.95rem;
  }
</style>
