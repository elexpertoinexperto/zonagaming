---
import '../../styles.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import BestSellers from '../../components/BestSellers.astro';
import Comparador from '../../components/Comparador.astro';
import productos from '../../data/productos-en.json';
import { CATS_EN, SLUG_EN } from '../../i18n/en';

const tg  = (productos['tarjetas-graficas'] as any[]);
const cpu = (productos['procesadores'] as any[]);
const ram = (productos['memoria-ram'] as any[]);

const categories = Object.entries(CATS_EN).map(([key, cat]) => ({
  label: cat.label,
  slug: `/en/${SLUG_EN[key]}/`,
  icon: cat.icon,
  description: cat.cardDescription,
}));

const bestSellerProducts = [
  {
    id: 1,
    name: tg.find((p: any) => p.id === 1)?.nombre || '',
    description: tg.find((p: any) => p.id === 1)?.descripcion || '',
    price: `$${(tg.find((p: any) => p.id === 1)?.precio ?? 0).toFixed(2)} USD`,
    imageUrl: tg.find((p: any) => p.id === 1)?.imagenUrl || '/placeholder-product.svg',
    detailHref: `/en/graphics-cards/${tg.find((p: any) => p.id === 1)?.slug}-1/`,
    amazonHref: tg.find((p: any) => p.id === 1)?.enlaceAmazon || '',
  },
  {
    id: 2,
    name: cpu.find((p: any) => p.id === 1)?.nombre || '',
    description: cpu.find((p: any) => p.id === 1)?.descripcion || '',
    price: `$${(cpu.find((p: any) => p.id === 1)?.precio ?? 0).toFixed(2)} USD`,
    imageUrl: cpu.find((p: any) => p.id === 1)?.imagenUrl || '/placeholder-product.svg',
    detailHref: `/en/processors/${cpu.find((p: any) => p.id === 1)?.slug}-1/`,
    amazonHref: cpu.find((p: any) => p.id === 1)?.enlaceAmazon || '',
  },
  {
    id: 3,
    name: ram.find((p: any) => p.id === 1)?.nombre || '',
    description: ram.find((p: any) => p.id === 1)?.descripcion || '',
    price: `$${(ram.find((p: any) => p.id === 1)?.precio ?? 0).toFixed(2)} USD`,
    imageUrl: ram.find((p: any) => p.id === 1)?.imagenUrl || '/placeholder-product.svg',
    detailHref: `/en/ram-memory/${ram.find((p: any) => p.id === 1)?.slug}-1/`,
    amazonHref: ram.find((p: any) => p.id === 1)?.enlaceAmazon || '',
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/logo-fondoblanco.png" type="image/png" sizes="256x256" />
    <link rel="apple-touch-icon" href="/logo-fondoblanco.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="es-CO" href="https://monckeygamer.com/" />
    <link rel="alternate" hreflang="en-US" href="https://monckeygamer.com/en/" />
    <link rel="alternate" hreflang="x-default" href="https://monckeygamer.com/" />
    <meta name="description" content="PC gaming components at the best price: graphics cards, CPUs, RAM, SSDs and more. Premium quality with Amazon shipping. Build your setup!" />
    <title>PC Gaming Components | Monckey Gamer</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "OnlineStore",
      "name": "Monckey Gamer",
      "url": "https://monckeygamer.com/en/",
      "description": "Online store for PC gaming components: graphics cards, processors, RAM, SSDs and peripherals at the best price with Amazon shipping.",
      "email": "contacto@monckeygamer.com",
      "inLanguage": "en",
      "currenciesAccepted": "USD",
      "paymentAccepted": "Amazon",
      "priceRange": "$$",
      "hasMap": false,
      "sameAs": []
    })} />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5C73Q4ZW');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5C73Q4ZW"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div class="page">
      <Header />

      <section class="hero">
        <!-- Fondo animado synthwave (fullscreen) -->
        <div class="hero-bg">
          <div class="hv-grid"></div>
          <div class="hv-horizon"></div>
          <div class="hv-particles">
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span>
          </div>
          <div class="hv-scanline"></div>
        </div>

        <!-- Contenido con parallax -->
        <div class="hero-copy" id="hero-copy">
          <span class="hv-badge">● ONLINE</span>
          <h1>PC Components<br /><em>Gamer Store</em></h1>
          <p class="hero-copy-description">Gear and components that take your performance to the next level</p>
          <p>A curated catalog of PC-building parts — graphics cards, power supplies, mechanical keyboards and liquid cooling. Maximum speed and real gamer style.</p>
          <div class="hero-actions">
            <a class="btn" href="#coleccion">Best Sellers</a>
          </div>
          <div class="hero-stats">
            <div class="stat-card">
              <strong>+70</strong>
              Components for gaming.
            </div>
            <div class="stat-card">
              <strong>24h</strong>
              Available for you.
            </div>
            <div class="stat-card">
              <strong>Warranty</strong>
              Direct with Amazon.
            </div>
          </div>
        </div>

        <!-- Flecha de scroll -->
        <div class="hero-scroll-hint">
          <span>Scroll</span>
          <div class="hero-scroll-arrow"></div>
        </div>
      </section>

      <section id="categorias" class="categories">
        <div class="section-title">
          <small>Categories</small>
          <h2>Find the ideal component</h2>
        </div>
        <div class="category-grid">
          {categories.map((category) => (
            <a class="category-card" href={category.slug}>
              <span class="category-icon">
                <CategoryIcon name={category.icon} />
              </span>
              <div>
                <h3>{category.label}</h3>
                <p>{category.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <BestSellers
        id="coleccion"
        eyebrow="Top sellers"
        title="Best sellers"
        products={bestSellerProducts}
      />

      <Comparador lang="en" />

      <section id="ventajas" class="features">
        <div class="section-title">
          <small>Why visit Monckey Gamer</small>
          <h2>Gamer setup advantages</h2>
        </div>
        <div class="feature-list">
          <div class="feature-item">
            <div>1</div>
            <div class="feature-content">
              <strong>High-Quality Components</strong>
              <p>Here you will find the best components for your gaming setup, ready to buy through Amazon.</p>
            </div>
          </div>
          <div class="feature-item">
            <div>2</div>
            <div class="feature-content">
              <strong>Premium quality</strong>
              <p>We select components from well-known brands with stable, long-lasting performance.</p>
            </div>
          </div>
          <div class="feature-item">
            <div>3</div>
            <div class="feature-content">
              <strong>Interesting blogs</strong>
              <p>I publish an interesting blog with tips and updates about the gaming world.</p>
            </div>
          </div>
        </div>
      </section>

      <Footer />
    </div>
  </body>
</html>
