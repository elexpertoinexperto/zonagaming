---
import ProductCard from './ProductCard.astro';

type BestSellerProduct = {
  id?: number | string;
  name?: string;
  nombre?: string;
  description?: string;
  descripcion?: string;
  price?: string;
  precio?: number | string;
  href?: string;
  detailHref?: string;
  amazonHref?: string;
  enlaceAmazon?: string;
};

interface Props {
  products?: BestSellerProduct[];
  eyebrow?: string;
  title?: string;
  description?: string;
  id?: string;
}

const {
  products = [],
  eyebrow = 'Top ventas',
  title = 'Los más vendidos',  
  id = 'mas-vendidos',
} = Astro.props as Props;

const bestSellers = products.slice(0, 3).map((product) => ({
  id: product.id,
  name: product.name ?? product.nombre ?? '',
  description: product.description ?? product.descripcion ?? '',
  price:
    product.price ??
    (typeof product.precio === 'number' ? `$${product.precio.toFixed(2)} USD` : product.precio) ??
    '',
  detailHref: product.detailHref ?? product.href,
  amazonHref: product.amazonHref ?? product.enlaceAmazon,
}));
---

<section id={id} class="products best-sellers">
  <div class="section-title section-title-stacked">
    <div>
      <small>{eyebrow}</small>
      <h2>{title}</h2>
    </div>    
  </div>

  <div class="product-grid">
    {bestSellers.map((product) => (
      <ProductCard product={product} />
    ))}
  </div>
</section>
