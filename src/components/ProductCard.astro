---
type ProductCardData = {
  id?: number | string;
  name: string;
  description: string;
  price: string;
  imageUrl?: string;
  detailHref?: string;
  amazonHref?: string;
};

const { product, lang = 'es' } = Astro.props as { product: ProductCardData; lang?: 'es' | 'en' };
const tDetails = lang === 'en' ? 'Details' : 'Detalles';
const tImageOf = lang === 'en' ? 'Image of' : 'Imagen de';
---

<article class="product-card">
  <div class="product-card-content">
    <div>
      <h2>{product.name}</h2>
      <div class="product-card-image">
        <img
          src={product.imageUrl || '/placeholder-product.svg'}
          alt={`${tImageOf} ${product.name}`}
          loading="lazy"
        />
      </div>
      <p>{product.description}</p>
    </div>

    <div class="product-card-footer">
      <span>{product.price}</span>
       <div class="product-card-actions">
        {product.detailHref && (
          <a class="btn btn-small" href={product.detailHref}>{tDetails}</a>
        )}
        {product.amazonHref && (
          <a
            class="btn btn-small btn-amazon"
            href={product.amazonHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            Amazon
          </a>
        )}
      </div>
    </div>
  </div>
</article>
