---
import CategoryIcon from './CategoryIcon.astro';

const categories = [
  { label: 'Tarjetas gráficas', slug: '/tarjetas-graficas', icon: 'gpu' },
  { label: 'Procesadores', slug: '/procesadores', icon: 'cpu' },
  { label: 'Memoria RAM', slug: '/memoria-ram', icon: 'ram' },
  { label: 'SSD', slug: '/ssd', icon: 'ssd' },
  { label: 'Fuentes de poder', slug: '/fuentes-de-poder', icon: 'psu' },
  { label: 'Refrigeración líquida', slug: '/refrigeracion-liquida', icon: 'aio' },
  { label: 'Refrigeración normal', slug: '/refrigeracion-normal', icon: 'fan' },
  { label: 'Gabinetes gamer', slug: '/gabinetes-gamer', icon: 'box' },
  { label: 'Teclados', slug: '/teclados', icon: 'keyboard' },
  { label: 'Mouse', slug: '/mouse', icon: 'mouse' },
  { label: 'Audífonos', slug: '/audifonos', icon: 'audio' },
];
---

<header>
  <a href="/" class="brand">
    <img src="/logo.png" alt="Monckey Gamer" class="brand-logo" />
    Monckey Gamer
  </a>
  <button
    class="menu-toggle"
    id="mobile-menu-toggle"
    type="button"
    aria-label="Abrir menu"
    aria-controls="primary-nav"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="main-nav" id="primary-nav">
    <a href="/">Inicio</a>
    
    <!-- Dropdown de Componentes -->
    <div class="dropdown-container">
      <button class="dropdown-toggle" id="componentes-btn">
        Componentes
        <svg class="dropdown-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="dropdown-menu" id="componentes-menu">
        {categories.map((category) => (
          <a href={category.slug} class="dropdown-item">
            <span class="dropdown-category-symbol">
              <CategoryIcon name={category.icon} />
            </span>
            <span>{category.label}</span>
          </a>
        ))}
      </div>
    </div>

    <a href="/blog">Blog</a>
    <a href="#contacto">Contacto</a>
  </nav>
</header>

<script>
  const btn = document.getElementById('componentes-btn');
  const menu = document.getElementById('componentes-menu');
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const nav = document.getElementById('primary-nav');

  const closeMobileMenu = () => {
    if (!mobileToggle || !nav) return;

    mobileToggle.classList.remove('active');
    nav.classList.remove('active');
    mobileToggle.setAttribute('aria-expanded', 'false');
    mobileToggle.setAttribute('aria-label', 'Abrir menu');
  };

  if (btn && menu) {
    // Toggle del menú
    btn.addEventListener('click', () => {
      menu.classList.toggle('active');
    });

    // Cerrar menú al hacer click en un link
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('active');
      });
    });

    // Cerrar menú al hacer click fuera
    document.addEventListener('click', (e) => {
      if (e.target instanceof Node) {
        if (!btn.contains(e.target) && !menu.contains(e.target)) {
          menu.classList.remove('active');
        }
      }
    });
  }

  if (mobileToggle && nav) {
    mobileToggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('active');

      mobileToggle.classList.toggle('active', isOpen);
      mobileToggle.setAttribute('aria-expanded', String(isOpen));
      mobileToggle.setAttribute('aria-label', isOpen ? 'Cerrar menu' : 'Abrir menu');
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });

    document.addEventListener('click', (e) => {
      if (!(e.target instanceof Node)) return;

      if (!mobileToggle.contains(e.target) && !nav.contains(e.target)) {
        closeMobileMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeMobileMenu();
        menu?.classList.remove('active');
      }
    });
  }
</script>

<style>
  header {
    position: relative;
  }

  .main-nav {
    z-index: 1000;
  }

  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    color: #e6f7ff;
    cursor: pointer;
    padding: 10px;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .menu-toggle span + span {
    margin-top: 6px;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .dropdown-container {
    position: relative;
  }

  .dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    color: #c8d8e8;
    font-size: 0.95rem;
    font-family: Rubik, Inter, poppins;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  .dropdown-toggle:hover {
    color: #7cffcb;
  }

  .dropdown-icon {
    transition: transform 0.3s ease;
  }

  .dropdown-menu.active .dropdown-icon {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    min-width: 240px;
    background: rgba(7, 27, 53, 0.95);
    border: 1px solid rgba(124, 255, 203, 0.2);
    border-radius: 12px;
    padding: 8px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(8px);
    z-index: 1000;
  }

  .dropdown-menu.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    color: #c8d8e8;
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.9rem;
  }

  .dropdown-item:hover {
    background: rgba(124, 255, 203, 0.1);
    color: #7cffcb;
    padding-left: 20px;
  }

  .dropdown-category-symbol {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(124, 255, 203, 0.22);
    border-radius: 6px;
    color: #7cffcb;
    background: rgba(124, 255, 203, 0.08);
    flex: 0 0 auto;
  }

  .dropdown-category-symbol svg {
    width: 18px;
    height: 18px;
  }

  a.brand {
    text-decoration: none;
    color: inherit;
  }

  .brand-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .menu-toggle {
      display: block;
    }

    .main-nav {
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      left: 0;
      display: grid;
      gap: 6px;
      padding: 16px;
      border: 1px solid rgba(124, 255, 203, 0.18);
      border-radius: 16px;
      background: rgba(7, 27, 53, 0.96);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
      backdrop-filter: blur(10px);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    }

    .main-nav.active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }

    .main-nav > a,
    .dropdown-toggle {
      width: 100%;
      justify-content: space-between;
      padding: 12px;
      border-radius: 8px;
    }

    .main-nav > a:hover,
    .dropdown-toggle:hover {
      background: rgba(124, 255, 203, 0.08);
    }

    .dropdown-menu {
      position: static;
      min-width: 0;
      width: 100%;
      max-height: 0;
      overflow: hidden;
      padding: 0;
      border: 0;
      opacity: 1;
      visibility: visible;
      transform: none;
      background: rgba(255, 255, 255, 0.04);
      transition: max-height 0.2s ease, padding 0.2s ease;
    }

    .dropdown-menu.active {
      max-height: 560px;
      padding: 6px 0;
      transform: none;
    }

    .dropdown-item {
      padding: 10px 12px;
    }

    .dropdown-item:hover {
      padding-left: 16px;
    }
  }
</style>
