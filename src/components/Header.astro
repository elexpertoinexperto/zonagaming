---
import CategoryIcon from './CategoryIcon.astro';
import { CATS_EN, UI_EN, SLUG_EN, toEnPath, toEsPath } from '../i18n/en';

// Idioma derivado de la URL: /en/... es inglés
const pathname = Astro.url.pathname;
const isEn = pathname === '/en' || pathname.startsWith('/en/');
const prefix = isEn ? '/en' : '';

// Rutas equivalentes para el selector de idioma (slugs de categoría traducidos)
const esPath = toEsPath(pathname);
const enPath = toEnPath(esPath);

const categoriesEs = [
  { label: 'Tarjetas gráficas', key: 'tarjetas-graficas', icon: 'gpu' },
  { label: 'Procesadores', key: 'procesadores', icon: 'cpu' },
  { label: 'Memoria RAM', key: 'memoria-ram', icon: 'ram' },
  { label: 'SSD', key: 'ssd', icon: 'ssd' },
  { label: 'Fuentes de poder', key: 'fuentes-de-poder', icon: 'psu' },
  { label: 'Refrigeración líquida', key: 'refrigeracion-liquida', icon: 'aio' },
  { label: 'Refrigeración normal', key: 'refrigeracion-normal', icon: 'fan' },
  { label: 'Gabinetes gamer', key: 'gabinetes-gamer', icon: 'box' },
  { label: 'Teclados', key: 'teclados', icon: 'keyboard' },
  { label: 'Mouse', key: 'mouse', icon: 'mouse' },
  { label: 'Audífonos', key: 'audifonos', icon: 'audio' },
];

const categories = categoriesEs.map((c) => ({
  label: isEn ? CATS_EN[c.key].label : c.label,
  slug: isEn ? `/en/${SLUG_EN[c.key]}/` : `/${c.key}/`,
  icon: c.icon,
}));

const t = {
  home: isEn ? UI_EN.nav.home : 'Inicio',
  components: isEn ? UI_EN.nav.components : 'Componentes',
  blog: isEn ? UI_EN.nav.blog : 'Blog',
  contact: isEn ? UI_EN.nav.contact : 'Contacto',
};
---

<header>
  <a href={isEn ? '/en/' : '/'} class="brand">
    <img src="/logo.png" alt="Monckey Gamer" class="brand-logo" />
    Monckey Gamer
  </a>
  <button
    class="menu-toggle"
    id="mobile-menu-toggle"
    type="button"
    aria-label="Abrir menu"
    aria-controls="primary-nav"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="main-nav" id="primary-nav">
    <a href={isEn ? '/en/' : '/'}>{t.home}</a>

    <!-- Dropdown de Componentes -->
    <div class="dropdown-container">
      <button class="dropdown-toggle" id="componentes-btn">
        {t.components}
        <svg class="dropdown-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="dropdown-menu" id="componentes-menu">
        {categories.map((category) => (
          <a href={category.slug} class="dropdown-item">
            <span class="dropdown-category-symbol">
              <CategoryIcon name={category.icon} />
            </span>
            <span>{category.label}</span>
          </a>
        ))}
      </div>
    </div>

    <a href={`${prefix}/blog/`}>{t.blog}</a>
    <a href={`${prefix}/contacto/`}>{t.contact}</a>

    <!-- Selector de idioma -->
    <div class="lang-switch" aria-label="Idioma / Language">
      <a href={esPath} class={`lang-btn${!isEn ? ' lang-active' : ''}`} title="Español" aria-label="Versión en español">
        <svg class="lang-flag" viewBox="0 0 20 14" width="20" height="14" aria-hidden="true">
          <rect width="20" height="7" fill="#FCD116"/>
          <rect y="7" width="20" height="3.5" fill="#003893"/>
          <rect y="10.5" width="20" height="3.5" fill="#CE1126"/>
        </svg>
        <span>ES</span>
      </a>
      <a href={enPath} class={`lang-btn${isEn ? ' lang-active' : ''}`} title="English" aria-label="English version">
        <svg class="lang-flag" viewBox="0 0 20 14" width="20" height="14" aria-hidden="true">
          <rect width="20" height="14" fill="#b22234"/>
          <g fill="#fff">
            <rect y="1.6" width="20" height="1.1"/>
            <rect y="3.8" width="20" height="1.1"/>
            <rect y="6" width="20" height="1.1"/>
            <rect y="8.2" width="20" height="1.1"/>
            <rect y="10.4" width="20" height="1.1"/>
            <rect y="12.6" width="20" height="1.1"/>
          </g>
          <rect width="9" height="7" fill="#3c3b6e"/>
          <g fill="#fff">
            <circle cx="1.6" cy="1.4" r="0.5"/>
            <circle cx="4.5" cy="1.4" r="0.5"/>
            <circle cx="7.4" cy="1.4" r="0.5"/>
            <circle cx="3" cy="2.9" r="0.5"/>
            <circle cx="6" cy="2.9" r="0.5"/>
            <circle cx="1.6" cy="4.4" r="0.5"/>
            <circle cx="4.5" cy="4.4" r="0.5"/>
            <circle cx="7.4" cy="4.4" r="0.5"/>
            <circle cx="3" cy="5.9" r="0.5"/>
            <circle cx="6" cy="5.9" r="0.5"/>
          </g>
        </svg>
        <span>EN</span>
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('componentes-btn');
  const menu = document.getElementById('componentes-menu');
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const nav = document.getElementById('primary-nav');

  const closeMobileMenu = () => {
    if (!mobileToggle || !nav) return;

    mobileToggle.classList.remove('active');
    nav.classList.remove('active');
    mobileToggle.setAttribute('aria-expanded', 'false');
    mobileToggle.setAttribute('aria-label', 'Abrir menu');
  };

  if (btn && menu) {
    // Toggle del menú
    btn.addEventListener('click', () => {
      menu.classList.toggle('active');
    });

    // Cerrar menú al hacer click en un link
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('active');
      });
    });

    // Cerrar menú al hacer click fuera
    document.addEventListener('click', (e) => {
      if (e.target instanceof Node) {
        if (!btn.contains(e.target) && !menu.contains(e.target)) {
          menu.classList.remove('active');
        }
      }
    });
  }

  if (mobileToggle && nav) {
    mobileToggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('active');

      mobileToggle.classList.toggle('active', isOpen);
      mobileToggle.setAttribute('aria-expanded', String(isOpen));
      mobileToggle.setAttribute('aria-label', isOpen ? 'Cerrar menu' : 'Abrir menu');
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });

    document.addEventListener('click', (e) => {
      if (!(e.target instanceof Node)) return;

      if (!mobileToggle.contains(e.target) && !nav.contains(e.target)) {
        closeMobileMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeMobileMenu();
        menu?.classList.remove('active');
      }
    });
  }
</script>

<style>
  header {
    position: relative;
  }

  .main-nav {
    z-index: 1000;
  }

  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    color: #e6f7ff;
    cursor: pointer;
    padding: 10px;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .menu-toggle span + span {
    margin-top: 6px;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .dropdown-container {
    position: relative;
  }

  .dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    color: #c8d8e8;
    font-size: 0.95rem;
    font-family: Rubik, Inter, poppins;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  .dropdown-toggle:hover {
    color: #7cffcb;
  }

  .dropdown-icon {
    transition: transform 0.3s ease;
  }

  .dropdown-menu.active .dropdown-icon {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    min-width: 240px;
    background: rgba(7, 27, 53, 0.95);
    border: 1px solid rgba(124, 255, 203, 0.2);
    border-radius: 12px;
    padding: 8px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(8px);
    z-index: 1000;
  }

  .dropdown-menu.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    color: #c8d8e8;
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.9rem;
  }

  .dropdown-item:hover {
    background: rgba(124, 255, 203, 0.1);
    color: #7cffcb;
    padding-left: 20px;
  }

  .dropdown-category-symbol {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(124, 255, 203, 0.22);
    border-radius: 6px;
    color: #7cffcb;
    background: rgba(124, 255, 203, 0.08);
    flex: 0 0 auto;
  }

  .dropdown-category-symbol svg {
    width: 18px;
    height: 18px;
  }

  a.brand {
    text-decoration: none;
    color: inherit;
  }

  /* Selector de idioma con banderas */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
  }

  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #8aa0b8;
    text-decoration: none;
    opacity: 0.55;
    transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .lang-btn:hover {
    opacity: 1;
    color: #e6f7ff;
  }

  .lang-btn.lang-active {
    opacity: 1;
    color: #7cffcb;
    background: rgba(124, 255, 203, 0.08);
  }

  .lang-flag {
    border-radius: 2px;
    display: block;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15);
  }

  .brand-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .menu-toggle {
      display: block;
    }

    .main-nav {
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      left: 0;
      display: grid;
      gap: 6px;
      padding: 16px;
      max-height: calc(100svh - 100px);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      scrollbar-color: rgba(124, 255, 203, 0.4) transparent;
      border: 1px solid rgba(124, 255, 203, 0.18);
      border-radius: 16px;
      background: rgba(7, 27, 53, 0.96);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
      backdrop-filter: blur(10px);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    }

    .main-nav::-webkit-scrollbar {
      width: 6px;
    }

    .main-nav::-webkit-scrollbar-track {
      background: transparent;
    }

    .main-nav::-webkit-scrollbar-thumb {
      background: rgba(124, 255, 203, 0.4);
      border-radius: 999px;
    }

    .main-nav::-webkit-scrollbar-thumb:hover {
      background: rgba(124, 255, 203, 0.65);
    }

    .main-nav.active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }

    .main-nav > a,
    .dropdown-toggle {
      width: 100%;
      justify-content: space-between;
      padding: 12px;
      border-radius: 8px;
    }

    .main-nav > a:hover,
    .dropdown-toggle:hover {
      background: rgba(124, 255, 203, 0.08);
    }

    .dropdown-menu {
      position: static;
      min-width: 0;
      width: 100%;
      max-height: 0;
      overflow: hidden;
      padding: 0;
      border: 0;
      opacity: 1;
      visibility: visible;
      transform: none;
      background: rgba(255, 255, 255, 0.04);
      transition: max-height 0.2s ease, padding 0.2s ease;
    }

    .dropdown-menu.active {
      max-height: min(560px, 55vh);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      scrollbar-color: rgba(124, 255, 203, 0.4) transparent;
      padding: 6px 0;
      transform: none;
    }

    .dropdown-menu.active::-webkit-scrollbar {
      width: 6px;
    }

    .dropdown-menu.active::-webkit-scrollbar-track {
      background: transparent;
    }

    .dropdown-menu.active::-webkit-scrollbar-thumb {
      background: rgba(124, 255, 203, 0.4);
      border-radius: 999px;
    }

    .dropdown-menu.active::-webkit-scrollbar-thumb:hover {
      background: rgba(124, 255, 203, 0.65);
    }

    .dropdown-item {
      padding: 10px 12px;
    }

    .dropdown-item:hover {
      padding-left: 16px;
    }

    .lang-switch {
      justify-self: start;
      margin-top: 6px;
    }
  }
</style>
