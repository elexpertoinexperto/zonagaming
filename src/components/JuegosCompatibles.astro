      resolucion: '1080p',
      fps: '80+ FPS',
      setting: 'Medio',
      recomendado: {
        categoria: 'tarjetas-graficas',
        slug: 'hyperrender-rx-580-8gb',
        id: 3,
        nombre: 'HyperRender RX 580 8GB',
        razon: 'RX 580 + 16 GB es el build de entrada más completo para Apex Legends a 1080p.',
      },
    },
  ],
};

const key = `${categoria}-${productoId}`;
const juegos = (juegosMap[key] ?? []).slice(0, 3);

const catLabel: Record<string, string> = {
  'tarjetas-graficas': 'tarjeta gráfica',
  'procesadores': 'procesador',
  'memoria-ram': 'memoria RAM',
  'ssd': 'SSD',
  'refrigeracion-normal': 'refrigeración',
  'refrigeracion-liquida': 'refrigeración líquida',
};
---

{juegos.length > 0 && (
  <section class="juegos-section">
    <div class="juegos-header">
      <span class="juegos-chip">🎮 Gaming Guide</span>
      <h2>Juegos AAA que puedes correr con {productoNombre.split(' ').slice(0, 4).join(' ')}…</h2>
      <p class="juegos-subtitle">
        Guía orientativa basada en el rendimiento del hardware. Los FPS reales pueden variar según la configuración completa del sistema.
      </p>
    </div>

    <div class="juegos-grid">
      {juegos.map((juego) => (
        <div class="juego-card">
          {steamImg(juego.titulo) && (
            <img
              class="juego-img"
              src={steamImg(juego.titulo)!}
              alt={juego.titulo}
              loading="lazy"
              width="460"
              height="215"
            />
          )}
          <div class="juego-top">
            <div class="juego-info">
              <span class="juego-genero">{juego.genero}</span>
              <h3 class="juego-titulo">{juego.titulo}</h3>
            </div>
            <div class="juego-badges">
              <span class="badge-res">{juego.resolucion}</span>
              <span class="badge-fps">{juego.fps}</span>
            </div>
          </div>

          <div class="juego-setting">
            <span class="setting-label">Calidad gráfica</span>
            <span class="setting-value">{juego.setting}</span>
          </div>

          <div class="juego-rec">
            <span class="rec-label">Para sacarle el máximo:</span>
            <a
              class="rec-link"
              href={`/${juego.recomendado.categoria}/${juego.recomendado.slug}-${juego.recomendado.id}/`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="rec-cat">{catLabel[juego.recomendado.categoria]}</span>
              <span class="rec-nombre">{juego.recomendado.nombre}</span>
            </a>
            <p class="rec-razon">{juego.recomendado.razon}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .juegos-section {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .juegos-header {
    margin-bottom: 28px;
  }

  .juegos-chip {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7cffcb;
    background: rgba(124, 255, 203, 0.08);
    border: 1px solid rgba(124, 255, 203, 0.22);
    padding: 4px 12px;
    border-radius: 999px;
    margin-bottom: 14px;
  }

  .juegos-header h2 {
    margin: 0 0 10px;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: #e6f7ff;
    line-height: 1.3;
  }

  .juegos-subtitle {
    margin: 0;
    font-size: 0.83rem;
    color: #6a849a;
    line-height: 1.6;
  }

  .juegos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .juego-card {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .juego-card:hover {
    border-color: rgba(124, 255, 203, 0.25);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
  }

  .juego-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }

  .juego-top {
    padding: 0 22px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .juego-setting {
    margin: 0 22px;
  }

  .juego-rec {
    margin: 0 22px 22px;
  }

  .juego-genero {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8aa0b8;
    display: block;
    margin-bottom: 6px;
  }

  .juego-titulo {
    margin: 0;
    font-size: 1.1rem;
    color: #e6f7ff;
    line-height: 1.2;
  }

  .juego-badges {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex-shrink: 0;
  }

  .badge-res,
  .badge-fps {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 999px;
    white-space: nowrap;
    text-align: center;
  }

  .badge-res {
    background: rgba(27, 183, 255, 0.12);
    color: #1bb7ff;
    border: 1px solid rgba(27, 183, 255, 0.25);
  }

  .badge-fps {
    background: rgba(124, 255, 203, 0.1);
    color: #7cffcb;
    border: 1px solid rgba(124, 255, 203, 0.22);
  }

  .juego-setting {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .setting-label {
    font-size: 0.75rem;
    color: #6a849a;
    white-space: nowrap;
  }

  .setting-value {
    font-size: 0.82rem;
    font-weight: 600;
    color: #c8d8e8;
  }

  .juego-rec {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rec-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6a849a;
  }

  .rec-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    padding: 10px 14px;
    border-radius: 12px;
    background: rgba(124, 255, 203, 0.05);
    border: 1px solid rgba(124, 255, 203, 0.15);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .rec-link:hover {
    background: rgba(124, 255, 203, 0.1);
    border-color: rgba(124, 255, 203, 0.35);
  }

  .rec-cat {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7cffcb;
  }

  .rec-nombre {
    font-size: 0.88rem;
    font-weight: 600;
    color: #e6f7ff;
    line-height: 1.3;
  }

  .rec-razon {
    margin: 0;
    font-size: 0.78rem;
    color: #7a94aa;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .juegos-grid {
      grid-template-columns: 1fr;
    }

    .juego-top {
      flex-direction: column;
    }

    .juego-badges {
      flex-direction: row;
    }
  }
</style>
