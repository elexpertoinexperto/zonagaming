---
import '../styles.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
const { title, description, robots, schema, article } = Astro.props;

const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": description,
  "datePublished": article.dateISO,
  "dateModified": article.dateISO,
  "author": {
    "@type": "Organization",
    "name": "Monckey Gamer",
    "url": "https://monckeygamer.com/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Monckey Gamer",
    "url": "https://monckeygamer.com/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://monckeygamer.com/logo-fondoblanco.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
} : null;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/logo-fondoblanco.png" type="image/png" sizes="256x256" />
    <link rel="apple-touch-icon" href="/logo-fondoblanco.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={Astro.url.href} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
    {articleSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  </head>
  <body>
    <div class="page">
      <Header />

      <slot />

      <Footer />
    </div>
  </body>
</html>
