---
import '../styles.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { toEnPath, toEsPath } from '../i18n/en';
const { title, description, robots, schema, article } = Astro.props;

// Idioma derivado de la URL: /en/... es inglés, el resto español
const pathname = Astro.url.pathname;
const isEn = pathname === '/en' || pathname.startsWith('/en/');
const lang = isEn ? 'en' : 'es';

// Rutas equivalentes en cada idioma (slugs de categoría traducidos)
const esPath = toEsPath(pathname);
const enPath = toEnPath(esPath);

const site = (Astro.site?.href || 'https://monckeygamer.com/').replace(/\/$/, '');
const esUrl = `${site}${esPath}`;
const enUrl = `${site}${enPath}`;

const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": description,
  "datePublished": article.dateISO,
  "dateModified": article.dateISO,
  "inLanguage": lang,
  "author": {
    "@type": "Organization",
    "name": "Monckey Gamer",
    "url": "https://monckeygamer.com/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Monckey Gamer",
    "url": "https://monckeygamer.com/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://monckeygamer.com/logo-fondoblanco.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
} : null;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" /></noscript>
    <link rel="icon" href="/logo-fondoblanco.png" type="image/png" sizes="256x256" />
    <link rel="apple-touch-icon" href="/logo-fondoblanco.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="es-CO" href={esUrl} />
    <link rel="alternate" hreflang="en-US" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
    {articleSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  </head>
  <body>
    <div class="page">
      <Header />

      <slot />

      <Footer />
    </div>
  </body>
</html>
