---
import { CATS_EN, UI_EN, SLUG_EN, toEnPath, toEsPath } from '../i18n/en';

// Idioma derivado de la URL: /en/... es inglés
const pathname = Astro.url.pathname;
const isEn = pathname === '/en' || pathname.startsWith('/en/');
const prefix = isEn ? '/en' : '';

// Rutas equivalentes para el selector de idioma (slugs de categoría traducidos)
const esPath = toEsPath(pathname);
const enPath = toEnPath(esPath);

const catKeys = [
  'tarjetas-graficas', 'procesadores', 'memoria-ram', 'ssd', 'fuentes-de-poder',
  'refrigeracion-liquida', 'refrigeracion-normal', 'gabinetes-gamer', 'teclados', 'mouse', 'audifonos',
];

const labelsEs: Record<string, string> = {
  'tarjetas-graficas': 'Tarjetas gráficas',
  'procesadores': 'Procesadores',
  'memoria-ram': 'Memoria RAM',
  'ssd': 'SSD',
  'fuentes-de-poder': 'Fuentes de poder',
  'refrigeracion-liquida': 'Refrigeración líquida',
  'refrigeracion-normal': 'Refrigeración normal',
  'gabinetes-gamer': 'Gabinetes gamer',
  'teclados': 'Teclados',
  'mouse': 'Mouse',
  'audifonos': 'Audífonos',
};

const cats = catKeys.map((key) => ({
  href: isEn ? `/en/${SLUG_EN[key]}/` : `/${key}/`,
  label: isEn ? CATS_EN[key].label : labelsEs[key],
}));

const t = isEn
  ? {
      tagline1: UI_EN.footer.tagline1,
      tagline2: UI_EN.footer.tagline2,
      desc: UI_EN.footer.desc,
      badge: UI_EN.footer.badge,
      catalogs: UI_EN.footer.catalogs,
      info: UI_EN.footer.info,
      blog: 'Blog',
      contact: UI_EN.footer.contact,
      sitemap: UI_EN.footer.sitemap,
      made: UI_EN.footer.made,
    }
  : {
      tagline1: 'El setup perfecto',
      tagline2: 'empieza aquí.',
      desc: 'Componentes PC para gaming seleccionados al detalle. Envío rápido vía Amazon.',
      badge: 'Tienda activa · 24/7',
      catalogs: 'Catálogos',
      info: 'Información',
      blog: 'Blog',
      contact: 'Contacto',
      sitemap: 'Mapa del sitio',
      made: 'Hecho para gamers, por gamers',
    };
---

<footer>
  <div class="footer-glow"></div>

  <div class="footer-inner">
    <div class="footer-brand">
      <div class="footer-brand-logo">
        <img src="/logo-fondoblanco.png" alt="Monckey Gamer" width="40" height="40" />
        <span>Monckey Gamer</span>
      </div>
      <p class="footer-brand-tagline">{t.tagline1}<br /><em>{t.tagline2}</em></p>
      <p class="footer-brand-desc">{t.desc}</p>
      <div class="footer-brand-badge">
        <span class="badge-dot"></span>
        {t.badge}
      </div>
    </div>

    <div class="footer-divider"></div>

    <nav class="footer-nav" aria-label={t.catalogs}>
      <span class="footer-nav-title">{t.catalogs}</span>
      <ul>
        {cats.map((c) => (
          <li><a href={c.href}>{c.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label={t.info}>
      <span class="footer-nav-title">{t.info}</span>
      <ul>
        <li><a href={`${prefix}/blog/`}>{t.blog}</a></li>
        <li><a href={`${prefix}/contacto/`}>{t.contact}</a></li>
        <li><a href="/sitemap.xml">{t.sitemap}</a></li>
      </ul>

      <div class="footer-lang" aria-label="Idioma / Language">
        <a href={esPath} class={`footer-lang-btn${!isEn ? ' footer-lang-active' : ''}`} title="Español">
          <svg viewBox="0 0 20 14" width="18" height="13" aria-hidden="true">
            <rect width="20" height="7" fill="#FCD116"/>
            <rect y="7" width="20" height="3.5" fill="#003893"/>
            <rect y="10.5" width="20" height="3.5" fill="#CE1126"/>
          </svg>
          Español
        </a>
        <a href={enPath} class={`footer-lang-btn${isEn ? ' footer-lang-active' : ''}`} title="English">
          <svg viewBox="0 0 20 14" width="18" height="13" aria-hidden="true">
            <rect width="20" height="14" fill="#b22234"/>
            <g fill="#fff">
              <rect y="1.6" width="20" height="1.1"/>
              <rect y="3.8" width="20" height="1.1"/>
              <rect y="6" width="20" height="1.1"/>
              <rect y="8.2" width="20" height="1.1"/>
              <rect y="10.4" width="20" height="1.1"/>
              <rect y="12.6" width="20" height="1.1"/>
            </g>
            <rect width="9" height="7" fill="#3c3b6e"/>
            <g fill="#fff">
              <circle cx="1.6" cy="1.4" r="0.5"/>
              <circle cx="4.5" cy="1.4" r="0.5"/>
              <circle cx="7.4" cy="1.4" r="0.5"/>
              <circle cx="3" cy="2.9" r="0.5"/>
              <circle cx="6" cy="2.9" r="0.5"/>
              <circle cx="1.6" cy="4.4" r="0.5"/>
              <circle cx="4.5" cy="4.4" r="0.5"/>
              <circle cx="7.4" cy="4.4" r="0.5"/>
              <circle cx="3" cy="5.9" r="0.5"/>
              <circle cx="6" cy="5.9" r="0.5"/>
            </g>
          </svg>
          English
        </a>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">© 2026 Monckey Gamer</span>
    <span class="footer-made">{t.made} <span class="footer-heart">▲</span></span>
  </div>
</footer>

<style>
  footer {
    position: relative;
    margin-top: 100px;
    padding: 0 2rem 0;
    overflow: hidden;
  }

  /* Glow superior */
  .footer-glow {
    position: absolute;
    top: 0;
    left: 50%;
    translate: -50% 0;
    width: 600px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #7cffcb, transparent);
  }

  .footer-glow::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    translate: -50% -50%;
    width: 300px;
    height: 120px;
    background: radial-gradient(ellipse, rgba(124, 255, 203, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Watermark fondo */
  footer::before {
    content: 'MG';
    position: absolute;
    bottom: 20px;
    right: -20px;
    font-size: 18rem;
    font-weight: 900;
    color: rgba(124, 255, 203, 0.025);
    line-height: 1;
    pointer-events: none;
    letter-spacing: -0.05em;
    user-select: none;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.6fr 1px 1fr 1fr;
    gap: 0 56px;
    align-items: start;
    padding: 56px 0 48px;
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-brand-logo img {
    width: 36px;
    height: 36px;
    border-radius: 10px;
  }

  .footer-brand-logo span {
    font-size: 1rem;
    font-weight: 700;
    color: #e6f7ff;
    letter-spacing: 0.02em;
  }

  .footer-brand-tagline {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
    color: #e6f7ff;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .footer-brand-tagline em {
    font-style: normal;
    color: #7cffcb;
  }

  .footer-brand-desc {
    font-size: 0.88rem;
    color: #8aa0b8;
    line-height: 1.7;
    margin: 0;
    max-width: 280px;
  }

  .footer-brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #7cffcb;
    background: rgba(124, 255, 203, 0.06);
    border: 1px solid rgba(124, 255, 203, 0.15);
    border-radius: 100px;
    padding: 5px 14px 5px 10px;
    width: fit-content;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #7cffcb;
    box-shadow: 0 0 6px #7cffcb;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Divisor vertical */
  .footer-divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(180deg, transparent, rgba(255,255,255,0.07) 20%, rgba(255,255,255,0.07) 80%, transparent);
  }

  /* Nav */
  .footer-nav-title {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #7cffcb;
    margin-bottom: 20px;
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }

  .footer-nav a {
    color: #8aa0b8;
    text-decoration: none;
    font-size: 0.88rem;
    display: inline-flex;
    align-items: center;
    gap: 0;
    transition: color 0.2s ease, translate 0.2s ease;
    position: relative;
  }

  .footer-nav a::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: #7cffcb;
    transition: width 0.25s ease;
  }

  .footer-nav a:hover {
    color: #e6f7ff;
    translate: 4px 0;
  }

  .footer-nav a:hover::before {
    width: 100%;
  }

  /* Selector de idioma */
  .footer-lang {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 28px;
  }

  .footer-lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #8aa0b8;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .footer-lang-btn svg {
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .footer-lang-btn:hover {
    opacity: 1;
    color: #e6f7ff;
  }

  .footer-lang-active {
    opacity: 1;
    color: #7cffcb;
  }

  /* Bottom bar */
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 0 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    color: rgba(138, 160, 184, 0.6);
    font-size: 0.8rem;
  }

  .footer-made {
    color: rgba(138, 160, 184, 0.4);
    font-size: 0.78rem;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer-heart {
    color: #7cffcb;
    font-size: 0.6rem;
    opacity: 0.7;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer-divider {
      display: none;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-brand-tagline {
      font-size: 1.6rem;
    }
  }

  @media (max-width: 540px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }

    .footer-brand-tagline {
      font-size: 1.4rem;
    }
  }
</style>
